{
  "root": true,
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true,
    "mocha": true
  },
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "off",
    "no-undef": "off"
  },
  "ignorePatterns": ["node_modules/", "dist/", "coverage/", "test/"]
}
