{
  "root": true,
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true,
    "mocha": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "off",
    "no-undef": "error"
  },
  "ignorePatterns": ["node_modules/", "dist/", "coverage/"]
}
