{
    "root": true,
    "env": {
      "node": true,
      "es2021": true,
      "jest": true,
      "mocha": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
      "no-undef": "off",
      "eqeqeq": ["warn", "always"],
      "curly": "warn"
    },
    "ignorePatterns": [
      "node_modules/",
      "dist/",
      "build/",
      "coverage/",
      ".nyc_output/",
      "security-reports/",
      "*.min.js",
      "test/**/*.js"
    ]
  }