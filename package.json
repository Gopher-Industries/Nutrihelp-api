{
  "name": "nutrihelp-api",
  "version": "1.0.0",
  "description": "nutrihelp-api",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha ./test/**/*.test.js",
    "test:unit": "mocha ./test/**/*.test.js --timeout 5000",
    "test:ci": "npm test -- --reporter mocha-junit-reporter --reporter-options mochaFile=./test-results.xml",
    "lint": "eslint . --ext .js --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --ext .js --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "openapi:validate": "swagger-cli validate index.yaml",
    "validate-env": "node scripts/validateEnv.js",
    "precommit": "npm run lint && npm run format:check && npm test"
  },
  "jest": {
    "testMatch": [
      "**/test/**/*.js"
    ]
  },
  "keywords": [
    "NutriHelp",
    "health",
    "elderly",
    "senior"
  ],
  "author": "Gopher Industries",
  "license": "ISC",
  "dependencies": {
    "@sendgrid/mail": "8.1.3",
    "@supabase/supabase-js": "2.86.0",
    "base64-arraybuffer": "1.0.2",
    "bcrypt": "5.1.1",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "crypto": "1.0.1",
    "dotenv": "16.6.1",
    "express": "4.19.1",
    "express-rate-limit": "7.5.0",
    "express-validator": "7.2.1",
    "fs-extra": "11.3.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.9.2",
    "node-fetch": "3.3.2",
    "nodemailer": "8.0.2",
    "sinon": "18.0.0",
    "swagger-ui-express": "5.0.0",
    "twilio": "5.9.0",
    "yamljs": "0.3.0"
  },
  "devDependencies": {
    "axios": "1.13.2",
    "chai": "6.0.1",
    "chai-http": "5.1.2",
    "concurrently": "8.2.2",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "form-data": "4.0.2",
    "jest": "30.2.0",
    "mocha": "11.7.2",
    "mocha-junit-reporter": "2.2.1",
    "nodemon": "3.1.10",
    "prettier": "3.2.5",
    "proxyquire": "2.1.3",
    "supertest": "7.1.4",
    "swagger-cli": "4.0.4"
  }
}