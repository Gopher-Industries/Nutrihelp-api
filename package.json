{
  "name": "nutrihelp-api",
  "version": "1.0.0",
  "description": "🚀 NutriHelp API - Enterprise CI/CD Pipeline",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    
    "test": "mocha ./test/**/*.test.js --timeout 5000 --reporter spec --exit",
    "test:unit": "mocha ./test/unit/**/*.test.js --timeout 5000 --exit",
    "test:integration": "mocha ./test/integration/**/*.test.js --timeout 10000 --exit",
    "test:coverage": "nyc --reporter=lcov --reporter=text mocha ./test/**/*.test.js --exit",
    "test:watch": "mocha ./test/**/*.test.js --watch",
    
    "lint": "eslint . --ext .js --max-warnings=0",
    "lint:fix": "eslint . --ext .js --fix",
    
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    
    "openapi:validate": "swagger-cli validate index.yaml",
    "openapi:bundle": "swagger-cli bundle index.yaml -o openapi-bundled.yaml",
    
    "security:audit": "npm audit --audit-level=moderate",
    "security:outdated": "npm outdated --depth=0",
    
    "build": "node -c server.js",
    "build:check": "node -e \"require('./server.js')\"",
    
    "precommit": "npm run lint && npm run format:check && npm test",
    "validate": "npm run lint && npm run format:check && npm test && npm run openapi:validate && npm run security:audit",
    
    "prepare": "husky install",
    "validate-env": "node scripts/validateEnv.js"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-security": "1.7.1",
    "prettier": "3.2.5",
    "mocha": "11.7.2",
    "mocha-junit-reporter": "2.2.1",
    "mochawesome": "7.1.3",
    "chai": "6.0.1",
    "chai-http": "5.1.2",
    "supertest": "7.1.4",
    "nyc": "15.1.0",
    "sinon": "18.0.0",
    "proxyquire": "2.1.3",
    "swagger-cli": "4.0.4",
    "husky": "8.0.3",
    "lint-staged": "15.2.2"
  },
  "dependencies": {
    "@sendgrid/mail": "8.1.3",
    "@supabase/supabase-js": "2.86.0",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "4.19.1",
    "express-rate-limit": "7.5.0",
    "express-validator": "7.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.9.2",
    "node-fetch": "3.3.2",
    "nodemailer": "8.0.2",
    "swagger-ui-express": "5.0.0",
    "twilio": "5.9.0",
    "yamljs": "0.3.0"
  },
  "lint-staged": {
    "*.js": ["eslint --fix", "prettier --write"],
    "*.{json,md,yml,yaml}": ["prettier --write"]
  }
}