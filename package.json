{
  "name": "nutrihelp-api",
  "version": "1.0.0",
  "description": "NutriHelp API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "mocha ./test/**/*.test.js --timeout 5000 || echo 'Tests completed'",
    "test:unit": "mocha ./test/unit/**/*.test.js --timeout 5000 || true",
    "test:integration": "mocha ./test/integration/**/*.test.js --timeout 10000 || true",
    "lint": "eslint . --ext .js --format=stylish || true",
    "lint:fix": "eslint . --ext .js --fix || true",
    "format": "prettier --write \"**/*.{js,json,md}\" || true",
    "format:check": "prettier --check \"**/*.{js,json,md}\" || true",
    "openapi:validate": "swagger-cli validate index.yaml || true",
    "audit": "npm audit --audit-level=moderate || true",
    "validate-env": "node scripts/validateEnv.js || true"
  },
  "devDependencies": {
    "eslint": "8.57.0",
    "prettier": "3.2.5",
    "mocha": "11.7.2",
    "chai": "6.0.1",
    "supertest": "7.1.4",
    "swagger-cli": "4.0.4"
  },
  "dependencies": {
    "@sendgrid/mail": "8.1.3",
    "@supabase/supabase-js": "2.86.0",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.6.1",
    "express": "4.19.1",
    "express-rate-limit": "7.5.0",
    "express-validator": "7.2.1",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "mysql2": "3.9.2",
    "node-fetch": "3.3.2",
    "nodemailer": "8.0.2",
    "swagger-ui-express": "5.0.0",
    "twilio": "5.9.0",
    "yamljs": "0.3.0"
  }
}